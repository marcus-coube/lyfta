# identity — copie para .env e ajuste (nunca commitar o .env real).
# Ver backend/.env.example para a descrição completa de cada variável.

PORT=8081
# Role lyfta_app (sem BYPASSRLS, criada pela migration 0002_app_role) — RLS só
# tem efeito de verdade com uma role sem privilégio de superusuário/bypass.
DATABASE_URL=postgres://lyfta_app:lyfta_app_dev@localhost:5432/lyfta_identity?sslmode=disable

# CORS: origens separadas por vírgula (ex.: http://localhost:5173,https://app.lyfta.com).
CORS_ORIGINS=http://localhost:*

# JWT EdDSA (ed25519) — gerar com backend/scripts/gen-keys.sh (P0.3).
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# Service-to-service (header X-Internal-Token).
INTERNAL_TOKEN=dev-internal-token

# Resend (convites e recuperação de senha — P0.4). Sem chave em dev: usa
# logMailer (loga o link no stdout).
RESEND_API_KEY=
MAIL_FROM=Lyfta <no-reply@lyfta.app>

APP_ENV=development
