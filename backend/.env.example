# Variáveis comuns dos serviços Go (ver backend/README.md).
# Copie para .env em cada serviço (backend/<svc>/.env) e ajuste — nunca commitar
# o .env real.

# Porta HTTP do serviço (uma por serviço: identity 8081, workout 8082,
# assessment 8083, comms 8084).
PORT=8081

# Postgres local da máquina — um banco por serviço (ADR-013). Troque o nome do
# banco conforme o serviço (lyfta_identity, lyfta_workout, lyfta_assessment,
# lyfta_comms).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lyfta_identity?sslmode=disable

# Par de chaves EdDSA (ed25519) para JWT — gerar com backend/scripts/gen-keys.sh.
# JWT_PRIVATE_KEY só é necessária no identity (quem assina); os demais serviços
# só precisam da pública para validar.
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# Token compartilhado para chamadas service-to-service (header X-Internal-Token).
INTERNAL_TOKEN=dev-internal-token

# S3-compatible (MinIO no dev, ver docker-compose.yml). Usado por
# workout/assessment/comms para mídia via presigned URLs.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lyfta-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# E-mail transacional (Resend) — usado só pelo identity (convites, reset de senha).
RESEND_API_KEY=
MAIL_FROM=Lyfta <no-reply@lyfta.app>

# Redis — usado pelo comms (chat WS, filas).
REDIS_URL=redis://localhost:6379/0
